# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================

# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (for admin commands)
ADMIN_ID=your_admin_user_id_here

# Channel subscription gate
REQUIRED_CHANNEL_USERNAME=@your_channel_username
FREE_MUSIC_REQUEST_LIMIT=3


# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# Full connection string (usually auto-generated from below)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/music_bot

# Individual settings
DB_USER=music_bot_user
DB_PASSWORD=secure_password_here
DB_NAME=music_bot_db
DB_HOST=postgres          # 'postgres' if using Docker, 'localhost' for local
DB_PORT=5432


# =============================================================================
# REDIS CACHE & QUEUE
# =============================================================================

# Full connection string (usually auto-generated from below)
# REDIS_URL=redis://localhost:6379/0

# Individual settings
REDIS_HOST=redis          # 'redis' if using Docker, 'localhost' for local
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=           # Leave empty if no password
REDIS_ENABLED=true


# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

APP_NAME=Finder Music Bot
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# Download limits
MAX_CONCURRENT_DOWNLOADS=3
DOWNLOAD_TIMEOUT=300

# Cache settings
CACHE_DIR=./cache
CACHE_TTL=600             # Search cache TTL in seconds (10 min)
CACHE_FILE_TTL=604800     # File cache TTL in seconds (7 days)
CACHE_MAX_SIZE_GB=10      # Max cache size before cleanup


# =============================================================================
# FILE SIZE LIMITS
# =============================================================================

# Regular user limit
MAX_FILE_SIZE_MB=50

# Premium user limit
PREMIUM_FILE_SIZE_MB=2000


# =============================================================================
# AUDIO/VIDEO QUALITY SETTINGS
# =============================================================================

# Default quality for new users
DEFAULT_AUDIO_BITRATE=192
DEFAULT_VIDEO_RESOLUTION=720

# Available options (comma-separated)
SUPPORTED_AUDIO_BITRATES=96,128,192,320
SUPPORTED_VIDEO_RESOLUTIONS=480,720,1080


# =============================================================================
# CLOUD STORAGE (FOR LARGE FILES > 50MB)
# =============================================================================

# -------- Google Drive --------
# 1. Go to https://console.cloud.google.com/
# 2. Create a project and enable Google Drive API
# 3. Create service account credentials
# 4. Download JSON and set GOOGLE_DRIVE_CREDENTIALS_PATH

GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_CREDENTIALS=/app/secrets/google-credentials.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here


# -------- Dropbox --------
# 1. Go to https://www.dropbox.com/developers/apps
# 2. Create an app and generate access token
# 3. Paste token below

DROPBOX_ENABLED=false
DROPBOX_TOKEN=your_dropbox_access_token_here


# =============================================================================
# MUSIC STREAMING SERVICES
# =============================================================================

# -------- Spotify --------
# NOTE: Used only for search on YouTube by artist/track name
# Visit https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here


# =============================================================================
# FFMPEG
# =============================================================================

# Path to ffmpeg binary
# On Linux: /usr/bin/ffmpeg
# On macOS: /usr/local/bin/ffmpeg
# On Windows: C:\\ffmpeg\\bin\\ffmpeg.exe
# Or just 'ffmpeg' if in PATH

FFMPEG_PATH=ffmpeg


# =============================================================================
# RATE LIMITING (PER-USER REQUESTS)
# =============================================================================

RATE_LIMIT_REQUESTS=5     # Max requests per window
RATE_LIMIT_WINDOW=60      # Time window in seconds

